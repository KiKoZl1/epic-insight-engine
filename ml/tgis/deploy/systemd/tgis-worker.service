[Unit]
Description=TGIS worker tick
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/uefntoolkit
EnvironmentFile=%h/uefntoolkit/ml/tgis/deploy/worker.env
ExecStart=%h/.venv_tgis/bin/python -m ml.tgis.runtime.worker_tick --config %h/uefntoolkit/ml/tgis/configs/base.yaml

[Install]
WantedBy=multi-user.target

