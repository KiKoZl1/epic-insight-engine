VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-key>"
SUPABASE_URL="https://<your-project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"
# For running SQL via terminal (psql) against your Supabase project.
# Format:
# postgresql://postgres:<db_password>@db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_URL="postgresql://postgres:<db_password>@db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require"
OPENAI_API_KEY="<your-openai-api-key>"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_TRANSLATION_MODEL="gpt-4.1-mini"
NVIDIA_API_KEY="<your-nvidia-api-key>"
NVIDIA_LOOKUP_MODEL="moonshotai/kimi-k2.5"
